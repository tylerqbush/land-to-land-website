---
pagination:
  data: properties
  size: 1
  alias: prop
permalink: "property/{{ prop.slug }}/index.html"
layout: base.njk
---
{%- set title = prop.name + " | Land to Land Holdings" -%}
{%- set description = prop.description -%}

{# ── HERO ── #}
<div class="listing-hero">
  <img class="listing-hero__img" src="{{ prop.photos[0] }}" alt="{{ prop.name }}" fetchpriority="high">
  <div class="listing-hero__overlay"></div>
  <div class="listing-hero__content">
    <div class="container">
      <span class="badge badge-{{ prop.status | lower | replace(' ', '-') | replace('under-contract', 'contract') }} mb-3" style="display:inline-block;">{{ "Available" if (prop.status | trim) == "Active" else prop.status }}</span>
      <h1 class="listing-hero__title">{{ prop.name }}</h1>
      <p class="listing-hero__meta">{{ prop.acreage }} acres &middot; {{ prop.county }} County, {{ prop.state }} &middot; {{ prop.id }}</p>
    </div>
  </div>
</div>

{# ── NARRATIVE: PHOTO GRID + "WHAT YOU'RE ACTUALLY GETTING" ── #}
<section class="section listing-narrative-section">
  <div class="container">
    <div class="listing-narrative-grid">

      {# LEFT: static photo grid #}
      <div class="listing-photo-grid">
        <a href="{{ prop.photos[0] }}" target="_blank" rel="noopener" class="listing-photo-grid__main js-lightbox-trigger" data-photos="{{ prop.photos | json }}" data-index="0">
          <img src="{{ prop.photos[0] }}" alt="Main photo of {{ prop.name }}" fetchpriority="high" width="900" height="600">
        </a>
        {% if prop.photos.length > 1 %}
        <div class="listing-photo-grid__thumbs">
          <a href="{{ prop.photos[1] }}" target="_blank" rel="noopener" class="listing-photo-grid__thumb js-lightbox-trigger" data-photos="{{ prop.photos | json }}" data-index="1">
            <img src="{{ prop.photos[1] }}" alt="Photo 2 of {{ prop.name }}" loading="lazy" width="480" height="320">
          </a>
          {% if prop.photos.length > 2 %}
          <a href="{{ prop.photos[2] }}" target="_blank" rel="noopener" class="listing-photo-grid__thumb listing-photo-grid__thumb--more js-lightbox-trigger" data-photos="{{ prop.photos | json }}" data-index="2">
            <img src="{{ prop.photos[2] }}" alt="Photo 3 of {{ prop.name }}" loading="lazy" width="480" height="320">
            {% if prop.photos.length > 3 %}
            <span class="listing-photo-grid__count">+{{ prop.photos.length - 3 }} more</span>
            {% endif %}
          </a>
          {% endif %}
        </div>
        {% endif %}
      </div>

      {# Lightbox modal — hidden by default, populated by assets/js/lightbox.js #}
      <div id="photo-lightbox" class="lightbox-overlay" hidden>
        <button type="button" class="lightbox-close" aria-label="Close">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <button type="button" class="lightbox-prev" aria-label="Previous photo">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button type="button" class="lightbox-next" aria-label="Next photo">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
        <figure class="lightbox-figure">
          <img class="lightbox-img" src="" alt="">
          <figcaption class="lightbox-caption"></figcaption>
        </figure>
      </div>

      {# RIGHT: narrative + feature bullets #}
      <div class="listing-narrative-col">
        <p class="listing-eyebrow">Property at a Glance</p>
        <h2 class="listing-narrative-heading">What You're Actually Getting</h2>

        <div class="listing-narrative-body">
          {% if prop.narrative %}
            {{ prop.narrative | safe }}
          {% else %}
            <p>{{ prop.description }}</p>
          {% endif %}
        </div>

        {# Feature bullets — use generated ones if available, else auto-derive #}
        <ul class="listing-feature-bullets">
          {% if prop.narrative_bullets %}
            {% for b in prop.narrative_bullets %}
            <li class="listing-feature-bullet">
              <svg class="listing-feature-bullet__icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <div>
                <strong>{{ b.title }}</strong>
                <span>{{ b.description }}</span>
              </div>
            </li>
            {% endfor %}
          {% else %}
            {# Auto-derived bullets from property data #}
            {% set bc = 0 %}

            {% if bc < 3 and prop.flood_plain and 'no' in prop.flood_plain | lower %}
              <li class="listing-feature-bullet">
                <svg class="listing-feature-bullet__icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22C6.5 22 2 17.5 2 12S6.5 2 12 2s10 4.5 10 10-4.5 10-10 10z"/><polyline points="9 12 11 14 15 10"/></svg>
                <div><strong>No Flood Zone</strong><span>This parcel sits in Flood Zone X. No flood insurance required.</span></div>
              </li>
              {% set bc = bc + 1 %}
            {% endif %}

            {% if bc < 3 and prop.elevation and prop.elevation | trim %}
              <li class="listing-feature-bullet">
                <svg class="listing-feature-bullet__icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="3 20 9 4 15 14 19 10 21 20 3 20"/></svg>
                <div><strong>Elevated Site</strong><span>Located at {{ prop.elevation | trim }}, well above surrounding terrain.</span></div>
              </li>
              {% set bc = bc + 1 %}
            {% endif %}

            {% if bc < 3 and prop.zoning and prop.zoning | trim and 'no zoning' not in prop.zoning | lower and 'no "zoning"' not in prop.zoning | lower %}
              <li class="listing-feature-bullet">
                <svg class="listing-feature-bullet__icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6M9 12h6M9 15h4"/></svg>
                <div><strong>Clear Zoning</strong><span>{{ prop.zoning | trim | truncate(80, true, "...") }}</span></div>
              </li>
              {% set bc = bc + 1 %}
            {% endif %}

            {% if bc < 3 and prop.full_time_rv and prop.full_time_rv | lower | truncate(3, false, "") == "yes" %}
              <li class="listing-feature-bullet">
                <svg class="listing-feature-bullet__icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="8" width="15" height="10" rx="1"/><path d="M16 11h3l2 3H16v-3z"/><circle cx="5" cy="19" r="1.5"/><circle cx="13" cy="19" r="1.5"/></svg>
                <div><strong>Full-Time RV Living Allowed</strong><span>Park your rig permanently. No time limits.</span></div>
              </li>
              {% set bc = bc + 1 %}
            {% endif %}

            {% if bc < 3 and (prop.single_family_allowed and prop.single_family_allowed | trim) or (prop.manufactured_allowed and prop.manufactured_allowed | lower | truncate(3, false, "") == "yes") %}
              <li class="listing-feature-bullet">
                <svg class="listing-feature-bullet__icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9.5L12 3l9 6.5V21H3V9.5z"/><path d="M9 21v-8h6v8"/></svg>
                <div><strong>Build-Ready</strong><span>{% if prop.single_family_allowed and prop.single_family_allowed | trim %}Site-built homes permitted.{% endif %}{% if prop.manufactured_allowed and prop.manufactured_allowed | lower | truncate(3, false, "") == "yes" %} Manufactured homes also allowed.{% endif %}</span></div>
              </li>
              {% set bc = bc + 1 %}
            {% endif %}

            {% if bc < 3 and prop.solar and prop.solar | lower | truncate(3, false, "") == "yes" %}
              <li class="listing-feature-bullet">
                <svg class="listing-feature-bullet__icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/><line x1="4.22" y1="4.22" x2="7.05" y2="7.05"/><line x1="16.95" y1="16.95" x2="19.78" y2="19.78"/><line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/><line x1="4.22" y1="19.78" x2="7.05" y2="16.95"/><line x1="16.95" y1="7.05" x2="19.78" y2="4.22"/></svg>
                <div><strong>Solar-Ready</strong><span>Solar power is a viable energy option for this parcel.</span></div>
              </li>
              {% set bc = bc + 1 %}
            {% endif %}

          {% endif %}
        </ul>

      </div>
    </div>
  </div>
</section>

{# ── PRICING ── #}
<section class="section listing-pricing-section">
  <div class="container">
    <div class="listing-price-inline">
      <p class="listing-price__monthly">${{ prop.monthly }}<span>/mo</span></p>
      {% if prop.term_months %}<p class="listing-price__term">for {{ prop.term_months }} months</p>{% endif %}
      <div class="listing-price__sub">
        <div class="listing-price__pill">
          <span class="listing-price__pill-label">Down</span>
          <span class="listing-price__pill-value">{% if prop.down %}${{ prop.down }}{% else %}TBD{% endif %}</span>
        </div>
        <div class="listing-price__pill">
          <span class="listing-price__pill-label">Doc Fee</span>
          <span class="listing-price__pill-value">{% if prop.doc_fee %}${{ prop.doc_fee }}{% else %}TBD{% endif %}</span>
        </div>
        <div class="listing-price__pill">
          <span class="listing-price__pill-label">Taxes/yr</span>
          <span class="listing-price__pill-value">{% if prop.annual_taxes %}${{ prop.annual_taxes }}{% else %}TBD{% endif %}</span>
        </div>
      </div>
      {% if prop.geekpay_url and (prop.status | trim) == "Active" %}
        <a href="{{ prop.geekpay_url }}" target="_blank" rel="noopener" class="btn-buy">Reserve This Property &rarr;</a>
      {% endif %}
      <a href="#ask-question" class="btn btn-outline btn-full" style="border-color:rgba(255,255,255,0.3);color:var(--color-white);">Ask a Question</a>
    </div>
  </div>
</section>

{# ── LIFESTYLE: WHY BUYERS CHOOSE THIS MARKET ── #}
{% set market = marketLifestyle.markets[prop.state] or marketLifestyle.fallback %}
<section class="lifestyle-section">
  <div class="container">
    <p class="listing-eyebrow text-center">Quick Look</p>
    <h2 class="lifestyle-section__heading">{{ market.heading }}</h2>
    <p class="lifestyle-section__subtext">{{ market.subtext }}</p>
    <div class="lifestyle-row">
      {% for item in market.items %}
      <div class="lifestyle-item">
        {{ marketLifestyle.icons[item.icon] | safe }}
        <span>{{ item.title }}</span>
        <p>{{ item.description }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ── RULES & ZONING ── #}
<section class="section section-off">
  <div class="container">
    <p class="eyebrow mb-2" style="color:var(--color-terra);">Allowable Uses</p>
    <h2 class="heading-md mb-6">Property Rules &amp; Zoning</h2>
    <div class="rules-grid">
      {% set rules = [
        ["Single Family Home", prop.single_family_allowed],
        ["Modular Home", prop.modular_allowed],
        ["Manufactured Home", prop.manufactured_allowed],
        ["Tiny Home", prop.tiny_home_friendly],
        ["Full-Time RV Living", prop.full_time_rv],
        ["RV While Building", prop.rv_while_build],
        ["Camping (RV)", prop.camping_rv],
        ["Tent Camping", prop.tent_camping]
      ] %}
      {% for rule in rules %}
        {% if rule[1] == "Yes" or rule[1] == "No" %}
          <div class="rule-item">
            {% if rule[1] == "Yes" %}
              <span class="rule-item__check rule-item__check--yes">&#10003;</span>
            {% else %}
              <span class="rule-item__check rule-item__check--no">&#10007;</span>
            {% endif %}
            <span class="rule-item__label">{{ rule[0] }}</span>
          </div>
        {% endif %}
      {% endfor %}
      {# Flood plain: inverted — "No" is the good answer #}
      {% if prop.flood_plain == "Yes" or prop.flood_plain == "No" %}
        <div class="rule-item">
          {% if prop.flood_plain == "No" %}
            <span class="rule-item__check rule-item__check--yes">&#10003;</span>
          {% else %}
            <span class="rule-item__check rule-item__check--no">&#10007;</span>
          {% endif %}
          <span class="rule-item__label">Not in Flood Plain</span>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{# ── FINANCING OPTIONS ── #}
<section class="financing-section">
  <div class="container">
    <p class="eyebrow mb-2" style="color:rgba(255,255,255,0.5);">No Banks. No Credit Check.</p>
    <h2 class="heading-md mb-6" style="color:var(--color-white);">Financing Options</h2>
    <div class="financing-grid">
      <div class="financing-cash-card">
        <p class="financing-cash-card__label">Cash Offer?</p>
        <p class="financing-cash-card__price" style="font-size:22px;line-height:1.3;">We accept all reasonable cash offers.</p>
        <p style="font-size:14px;color:rgba(255,255,255,0.6);margin:var(--space-3) 0 var(--space-4);">Contact us to discuss pricing.</p>
        <a href="#ask-question" class="btn btn-primary btn-full mt-4">Get in Touch</a>
      </div>
      <div class="financing-terms-card">
        <p class="financing-terms-card__label">Owner Financing</p>
        <table class="financing-table">
          <tr><td>Monthly Payment</td><td>${{ prop.monthly }}/mo{% if prop.term_months %} for {{ prop.term_months }} months{% endif %}</td></tr>
          <tr><td>Down Payment</td><td>{% if prop.down %}${{ prop.down }}{% else %}TBD{% endif %}</td></tr>
          <tr><td>Document Fee</td><td>{% if prop.doc_fee %}${{ prop.doc_fee }}{% else %}TBD{% endif %}</td></tr>
          <tr><td>Annual Taxes</td><td>{% if prop.annual_taxes %}${{ prop.annual_taxes }}{% else %}TBD{% endif %}</td></tr>
          <tr><td>Credit Check</td><td>None</td></tr>
          <tr><td>Bank Required</td><td>No</td></tr>
        </table>
        {% if prop.geekpay_url and (prop.status | trim) == "Active" %}
          <a href="{{ prop.geekpay_url }}" target="_blank" rel="noopener" class="btn-buy mt-4" style="display:block;">Reserve This Property &rarr;</a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% if prop.video_url %}
{# ── VIDEO (facade: loads thumbnail, swaps to iframe on click) ── #}
{% set yt_id = prop.video_url | replace("https://www.youtube.com/embed/", "") | replace("https://youtu.be/", "") %}
<section class="section">
  <div class="container" style="max-width:780px;">
    <div class="yt-facade" data-src="{{ prop.video_url }}?autoplay=1" aria-label="Play property video" role="button" tabindex="0">
      <img class="yt-facade__thumb" src="https://img.youtube.com/vi/{{ yt_id }}/hqdefault.jpg" loading="lazy" decoding="async" alt="Property video thumbnail" width="480" height="360">
      <button class="yt-facade__btn" aria-label="Play video">
        <svg viewBox="0 0 68 48" width="68" height="48"><path d="M66.52 7.74C65.69 4.66 63.29 2.22 60.23 1.38 54.98 0 34 0 34 0S13.02 0 7.77 1.38C4.71 2.22 2.31 4.66 1.48 7.74 0 13.05 0 24 0 24s0 10.95 1.48 16.26c.83 3.08 3.23 5.52 6.29 6.36C13.02 48 34 48 34 48s20.98 0 26.23-1.38c3.06-.84 5.46-3.28 6.29-6.36C68 34.95 68 24 68 24s0-10.95-1.48-16.26z" fill="#ff0000"/><path d="M45 24 27 14v20" fill="#fff"/></svg>
      </button>
    </div>
  </div>
</section>
<script>
  document.querySelectorAll('.yt-facade').forEach(function(el) {
    function load() {
      var iframe = document.createElement('iframe');
      iframe.src = el.dataset.src;
      iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture');
      iframe.setAttribute('allowfullscreen', '');
      iframe.style.cssText = 'border:0;display:block;width:100%;height:100%;';
      el.replaceWith(iframe);
    }
    el.addEventListener('click', load);
    el.addEventListener('keydown', function(e) { if (e.key === 'Enter' || e.key === ' ') load(); });
  });
</script>
{% endif %}

{# ── DETAIL TABLE ── #}
<section class="section section-off">
  <div class="container">
    <p class="eyebrow mb-2" style="color:var(--color-terra);">Full Specs</p>
    <h2 class="heading-md mb-6">For the Detail Oriented</h2>
    <p style="font-size:14px;color:var(--color-text-muted);margin-bottom:var(--space-6);max-width:640px;">We know that detail-oriented buyers want the full picture. That's why we've included every bit of information we have about this property. If you have questions, reach out and we'll do our best to help.</p>

    <div class="disclaimer mb-6">READ THIS: We are not the Planning and Zoning department and while we try to answer common questions about what the property can be used for, we can't provide a yes or no answer for every circumstance. Land to Land Holdings LLC or its affiliates make no warranty or guarantee, either expressed or implied relative to usability, the exact location, desirability, or usefulness of the properties. Buyer is solely responsible for determining the condition of the property. All information is deemed reliable but not guaranteed. Buyer is required to complete their own due diligence prior to purchasing.</div>

    <div class="detail-grid">
      <div>
        <p class="detail-group__heading">Location</p>
        <table class="listing-table">
          <tr><td>Property ID</td><td>{{ prop.id }}</td></tr>
          <tr><td>Address</td><td>{{ prop.address }}</td></tr>
          <tr><td>City</td><td>{{ prop.city }}</td></tr>
          <tr><td>County</td><td>{{ prop.county }}</td></tr>
          <tr><td>State</td><td>{{ prop.state }}</td></tr>
          <tr><td>GPS</td><td>{{ prop.gps }}</td></tr>
          <tr><td>Google Maps</td><td><a href="{{ prop.google_maps_url }}" target="_blank" rel="noopener" style="color:var(--color-forest);font-weight:700;">Open &rarr;</a></td></tr>
        </table>
      </div>
      <div>
        <p class="detail-group__heading">Property</p>
        <table class="listing-table">
          <tr><td>APN</td><td>{{ prop.apn }}</td></tr>
          {% if prop.subdivision %}<tr><td>Subdivision</td><td>{{ prop.subdivision }}</td></tr>{% endif %}
          <tr><td>Zoning</td><td>{{ prop.zoning }}</td></tr>
          <tr><td>Acreage</td><td>{{ prop.acreage_display }}</td></tr>
          <tr><td>Dimensions</td><td>{{ prop.lot_dimensions }}</td></tr>
          <tr><td>Terrain</td><td>{{ prop.terrain }}</td></tr>
          <tr><td>Elevation</td><td>{{ prop.elevation }}</td></tr>
          <tr><td>Road Access</td><td>{{ prop.road_access }}</td></tr>
        </table>
      </div>
      <div>
        <p class="detail-group__heading">Utilities</p>
        <table class="listing-table">
          <tr><td>Water/Well</td><td>{{ prop.well }}</td></tr>
          <tr><td>Sewer/Septic</td><td>{{ prop.septic }}</td></tr>
          <tr><td>Electricity</td><td>{{ prop.electricity }}</td></tr>
          <tr><td>Solar</td><td>{{ prop.solar }}</td></tr>
          <tr><td>Propane</td><td>{{ prop.propane }}</td></tr>
          <tr><td>Gas</td><td>{{ prop.gas }}</td></tr>
        </table>
      </div>
      <div>
        <p class="detail-group__heading">Building</p>
        <table class="listing-table">
          <tr><td>Time Limit to Build</td><td>{{ prop.time_limit_to_build }}</td></tr>
          <tr><td>Single Family</td><td>{{ prop.single_family_allowed }}</td></tr>
          <tr><td>Modular</td><td>{{ prop.modular_allowed }}</td></tr>
          <tr><td>Manufactured</td><td>{{ prop.manufactured_allowed }}</td></tr>
          <tr><td>Tiny Home</td><td>{{ prop.tiny_home_friendly }}</td></tr>
          <tr><td>Septic Required</td><td>{{ prop.septic_required }}</td></tr>
          <tr><td>Flood Plain</td><td>{{ prop.flood_plain }}</td></tr>
        </table>
      </div>
    </div>
  </div>
</section>

{# ── FULL-BLEED PHOTO BREAK ── #}
{% if prop.photos[0] %}
<div class="listing-photo-break">
  <img src="{{ prop.photos[0] }}" alt="{{ prop.name }}" loading="lazy">
</div>
{% endif %}

{# ── LOCATION ── #}
<section class="section">
  <div class="container">
    <p class="eyebrow mb-2" style="color:var(--color-terra);">Where You'll Own</p>
    <h2 class="heading-md mb-4">Location</h2>
    {% if prop.lat and prop.lng %}
      <iframe
        src="https://maps.google.com/maps?q={{ prop.lat }},{{ prop.lng }}&z=14&output=embed"
        width="100%"
        height="400"
        style="border:0;border-radius:var(--radius-card);display:block;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Property location map"></iframe>
    {% endif %}
    <p class="mt-4" style="font-size:13px;color:var(--color-text-muted);">GPS: {{ prop.gps }} | <a href="{{ prop.google_maps_url }}" target="_blank" rel="noopener" style="color:var(--color-forest);font-weight:700;">Open in Google Maps &rarr;</a></p>
  </div>
</section>

{# ── ASK A QUESTION ── #}
<section class="section section-off" id="ask-question">
  <div class="container" style="max-width:640px;">
    <p class="eyebrow mb-2" style="color:var(--color-terra);">Get in Touch</p>
    <h2 class="heading-md mb-2">Have Questions?</h2>
    <p style="color:var(--color-text-muted);margin-bottom:var(--space-6);">Reach out directly and we'll get back to you fast.</p>
    <div style="display:flex;gap:var(--space-3);flex-wrap:wrap;">
      <a href="tel:6783361879" class="btn btn-primary">Call 678-336-1879</a>
      <a href="mailto:info@landtolandholdings.com" class="btn btn-outline">Email Us</a>
    </div>
  </div>
</section>

<script src="/assets/js/lightbox.js" defer></script>
