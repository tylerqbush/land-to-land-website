{# Usage: {% include "partials/property-card.njk" %} with `prop` in scope #}
<article class="property-card"
  data-state="{{ prop.state }}"
  data-county="{{ prop.county }}"
  data-status="{{ prop.status }}">
  <a href="/property/{{ prop.slug }}/" class="property-card__photo">
    <img
      src="{{ prop.photos[0] }}"
      alt="{{ prop.acreage }} acre property in {{ prop.county }}, {{ prop.state }}"
      loading="lazy"
      width="480"
      height="270">
    <div class="property-card__overlay">
      <p class="property-card__acres">{{ prop.acreage }} ACRES</p>
      <p class="property-card__location">{{ prop.county | upper }}, {{ prop.state }}</p>
      <span class="badge badge-{{ prop.status | lower | replace(' ', '-') | replace('under-contract', 'contract') }}">{{ prop.status }}</span>
    </div>
  </a>
  <div class="property-card__footer">
    <div>
      <span class="property-card__price">${{ prop.monthly }}<span class="property-card__price-unit">/mo</span></span>
      <div class="mt-2">
        <a href="https://link.acrematic.com/widget/booking/NZxhdH02tv2KlHXB3vTs" target="_blank" rel="noopener" class="savings-tag">Ask how to save $247</a>
      </div>
    </div>
    <a href="/property/{{ prop.slug }}/" class="btn btn-primary property-card__cta">Learn More</a>
  </div>
</article>
