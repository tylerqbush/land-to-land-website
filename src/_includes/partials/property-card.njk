{# Usage: {% include "partials/property-card.njk" %} with `prop` in scope #}
<article class="property-card"
  data-state="{{ prop.state }}"
  data-county="{{ prop.county }}"
  data-status="{{ prop.status }}">
  <a href="/property/{{ prop.slug }}/" class="property-card__photo">
    <img
      src="{{ prop.photos[0] }}"
      alt="{{ prop.acreage }} acre property in {{ prop.county }}, {{ prop.state }}"
      loading="lazy"
      width="480"
      height="360">
    <div class="property-card__badge">
      <span class="badge badge-{{ prop.status | lower | replace(' ', '-') | replace('under-contract', 'contract') }}">{{ "Available" if (prop.status | trim) == "Active" else (prop.status | trim) }}</span>
    </div>
    <div class="property-card__overlay">
      <p class="property-card__acres">{{ prop.acreage }}</p>
      <p class="property-card__location">{{ prop.county }}, {{ prop.state }}</p>
    </div>
  </a>
  <div class="property-card__footer">
    <div class="property-card__price-group">
      <span class="property-card__name">{{ prop.county }} County, {{ prop.state }}</span>
      <span class="property-card__price">${{ prop.monthly }}<span class="property-card__price-unit">/mo</span></span>
    </div>
    <a href="/property/{{ prop.slug }}/" class="property-card__cta">Learn More</a>
  </div>
</article>
